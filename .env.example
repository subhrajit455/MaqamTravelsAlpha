# Environment Variables Configuration

# ─── Server ────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ───────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/travel-platform

# ─── JWT Authentication ────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_here_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# ─── CORS & Client URLs ────────────────────────────────
CLIENT_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# ─── CRM Configuration ─────────────────────────────────
CRM_PREFIX=/ops-crm

# ─── SRDV API Integration ──────────────────────────────
SRDV_BASE_URL=https://api.srdvtech.com
SRDV_API_KEY=your_srdv_api_key_here
SRDV_AGENT_ID=your_agent_id_here

# ─── Razorpay Payment Integration ─────────────────────
# Test Keys (from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Webhook Secret (from Razorpay Webhooks settings)
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_URL=https://yourdomain.com/webhook/razorpay/events

# ─── Other Payment Gateways (Future) ───────────────────
PHONEPE_MERCHANT_ID=your_phonepe_merchant_id
PHONEPE_SALT_KEY=your_phonepe_salt_key
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# ─── Email Notifications ───────────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key_here

# ─── SMS Notifications ─────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ─── Caching (Redis) ───────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Logging ────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ─── File Storage (S3/CDN) ─────────────────────────────
# For ticket PDFs, invoices, etc.
AWS_S3_BUCKET=your_bucket_name
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ap-south-1
// 